{
  "project": {
    "name": "core-be",
    "displayName": "core-be",
    "artifacts": {
      "apiImage": "core-be-api",
      "workerImage": "core-be-worker",
      "dockerLocalApiTag": "core-be",
      "ghcrCacheScopeApi": "core-be-api",
      "ghcrCacheScopeWorker": "core-be-worker"
    }
  },
  "git": {
    "protectedBranches": ["main"],
    "defaultBranch": "main"
  },
  "environments": [
    {
      "name": "development",
      "label": "Development",
      "nodeEnvironment": "development",
      "protected": true,
      "isDefault": true
    },
    {
      "name": "production",
      "label": "Production",
      "nodeEnvironment": "production",
      "protected": true
    }
  ],
  "providers": {
    "github": {
      "enabled": true,
      "repository": "nikunjmavani/core-be"
    }
  }
}
