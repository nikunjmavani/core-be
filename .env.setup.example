# =============================================================================
# Setup Tokens — Copy to .env.setup and fill in your API keys
# =============================================================================
# Each variable has the URL where to get the token.
# .env.setup is gitignored — never commit real tokens.
#
# Generated by setup:init. Edit tooling/setup/setup.config.json to change
# providers, environments, or branch mappings.
# =============================================================================

# --- Neon Postgres ---
# Get API key: https://console.neon.tech/app/settings/api-keys
# Create a new key, copy the value (starts with napi_)
NEON_API_KEY=

# Get Org ID: https://console.neon.tech/app/settings → Organization → General
NEON_ORG_ID=

# --- AWS ---
# Get access keys: https://console.aws.amazon.com/iam/home#/users
# Create an IAM user with AmazonS3FullAccess + IAMFullAccess
# Then Security credentials → Create access key → Application running outside AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Sentry ---
# Get auth token: https://sentry.io/settings/auth-tokens/new-token/
# Scopes needed: project:admin, project:write, project:read
SENTRY_AUTH_TOKEN=

# Get org slug: https://sentry.io/settings/ → Organization Settings → General
# Human-readable org slug used by sentry-cli (e.g. "albetrios").
SENTRY_ORG=

# --- Resend ---
# Get API key: https://resend.com/api-keys
# Create key with Full access permission
RESEND_API_KEY=

# --- GitHub ---
# Get personal access token: https://github.com/settings/tokens
# Classic token scopes: repo, admin:repo_hook
# When set, no gh auth login or browser prompt is needed.
GITHUB_TOKEN=

# --- Railway ---
# Account / project-wide token used at setup time. Authenticates via Bearer header.
# Get token: https://railway.com/account/tokens (NOT the per-project tokens page).
# Used to: create the project, list user projects, mint per-environment project
# tokens via `projectTokenCreate`, and read/write variables across environments.
# Stays in .env.setup only; never pushed to GitHub Environments or Railway service
# variables. Per-environment runtime tokens are minted from this and persisted to
# state, then written into each `.env.<env>` as `RAILWAY_TOKEN`.
RAILWAY_API_TOKEN=

# --- Postman ---
# Get API key: https://go.postman.co/settings/me/api-keys
POSTMAN_API_KEY=

# Get Workspace ID: https://go.postman.co/workspaces → click workspace → copy from URL
POSTMAN_WORKSPACE_ID=

# --- Scalar ---
# Get API key: https://dashboard.scalar.com → Settings → API keys
SCALAR_API_KEY=

# Team namespace (registry path @<namespace>/apis/<slug>)
SCALAR_NAMESPACE=

# Registry slug (optional; defaults to core-be)
SCALAR_SLUG=

# --- Stripe (per environment) ---
# Get secret keys: https://dashboard.stripe.com/apikeys
# Development: use TEST mode keys (sk_test_...)
# Production: use LIVE mode keys (sk_live_...)
# Get webhook secrets: https://dashboard.stripe.com/webhooks
STRIPE_DEVELOPMENT_SECRET_KEY=
STRIPE_DEVELOPMENT_WEBHOOK_SECRET=
STRIPE_PRODUCTION_SECRET_KEY=
STRIPE_PRODUCTION_WEBHOOK_SECRET=

# --- OAuth Google (per environment) ---
# Get credentials: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Web application
# Set redirect URIs per environment (e.g. http://localhost:3000/auth/oauth/google/callback)
OAUTH_GOOGLE_DEVELOPMENT_CLIENT_ID=
OAUTH_GOOGLE_DEVELOPMENT_CLIENT_SECRET=
OAUTH_GOOGLE_DEVELOPMENT_REDIRECT_URI=
OAUTH_GOOGLE_PRODUCTION_CLIENT_ID=
OAUTH_GOOGLE_PRODUCTION_CLIENT_SECRET=
OAUTH_GOOGLE_PRODUCTION_REDIRECT_URI=

# --- OAuth GitHub (per environment) ---
# Get OAuth app: https://github.com/settings/developers → New OAuth App
# Set callback URLs per environment (e.g. http://localhost:3000/auth/oauth/github/callback)
OAUTH_GITHUB_DEVELOPMENT_CLIENT_ID=
OAUTH_GITHUB_DEVELOPMENT_CLIENT_SECRET=
OAUTH_GITHUB_DEVELOPMENT_REDIRECT_URI=
OAUTH_GITHUB_PRODUCTION_CLIENT_ID=
OAUTH_GITHUB_PRODUCTION_CLIENT_SECRET=
OAUTH_GITHUB_PRODUCTION_REDIRECT_URI=
