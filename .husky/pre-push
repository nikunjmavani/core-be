#!/usr/bin/env sh
# Fast gate before push — full suite runs in CI (pnpm ci:local / pnpm test).

# Branch-name policy — keep working branches under the documented prefixes
# (docs/process/git-workflow.md). Long-lived env branches (dev, main) and
# Claude Code web session branches (claude/*) are allowlisted: the cloud git
# proxy pins a web session to push only its claude/* branch, so the platform's
# name is accepted as-is rather than rejected. Bypass once with:
#   SKIP_BRANCH_CHECK=1 git push
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo HEAD)
BRANCH_TYPES='feat|feature|fix|hotfix|refactor|docs|test|chore|ci|perf|build|style|revert'
if [ "${SKIP_BRANCH_CHECK:-0}" = "1" ] || [ "$BRANCH_NAME" = "HEAD" ]; then
  echo "Skipping branch-name policy on pre-push."
elif printf '%s' "$BRANCH_NAME" | grep -Eq "^(dev|main|claude/.+|(${BRANCH_TYPES})/.+)$"; then
  : # branch name follows policy
else
  echo "✗ Branch \"$BRANCH_NAME\" does not follow the naming policy."
  echo "  Use <type>/<short-description>, e.g. feature/ai-stream-response or fix/login-error."
  echo "  Allowed types: ${BRANCH_TYPES}"
  echo "  Long-lived: dev, main.  AI web sessions: claude/*."
  echo "  See docs/process/git-workflow.md.  Bypass once: SKIP_BRANCH_CHECK=1 git push"
  exit 1
fi

pnpm typecheck
pnpm build
pnpm build:check

# Markdown lint on the PR diff (mirrors pr-docs-lane.yml). lint-staged only
# touches staged files, but CI lints every changed markdown file in the PR
# (e.g. release-please-generated CHANGELOG-dev.md inherited from a rebase).
# Default base is origin/dev; override with LINT_BASE=origin/main.
PUSHED_MD=$(git diff --name-only @{u}...HEAD 2>/dev/null | grep -E '\.md$' || true)
if [ -n "$PUSHED_MD" ]; then
  pnpm docs:lint:changed
else
  echo "Skipping changed-markdown lint on pre-push (no markdown changes)."
fi

# Unit tests (matches PR CI unit lane; excludes DB project)
# Run only when pushed commits include unit-relevant files.
PUSHED_UNIT_RELEVANT=$(git diff --name-only @{u}...HEAD 2>/dev/null | rg \
  '^(src/|tooling/vitest/|vitest\.config\.ts$|package\.json$|pnpm-lock\.yaml$)' || true)
if [ -n "$PUSHED_UNIT_RELEVANT" ]; then
  pnpm test:unit
else
  echo "Skipping unit tests on pre-push (no unit-relevant changes)."
fi

# SonarQube quality gate — scans against the local SonarQube server and BLOCKS the push if any
# unresolved Sonar issue exists. Runs only when the pushed commits touch deployed-surface code
# (src/ runtime — the only thing Sonar analyzes; tests/scripts/tooling/docs are excluded). The
# gate auto-starts the server on first use (first boot ~2 min) and provisions a token in
# .env.local. Skip with SKIP_SONAR=1, or `git push --no-verify` to skip all hooks.
SONAR_BASE=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo origin/dev)
PUSHED_RUNTIME=$(git diff --name-only "$SONAR_BASE"...HEAD 2>/dev/null | rg '^src/.*\.ts$' | \
  rg -v '(__tests__/|\.test\.ts$|\.spec\.ts$|^src/tests/|^src/scripts/)' || true)
if [ "${SKIP_SONAR:-0}" = "1" ]; then
  echo "Skipping SonarQube gate on pre-push (SKIP_SONAR=1)."
elif [ -n "$PUSHED_RUNTIME" ]; then
  pnpm sonar:scan
else
  echo "Skipping SonarQube gate on pre-push (no deployed-surface code changes)."
fi
