# ── Layer 2: Pre-commit checks ───────────────────────────────

# 1. Lint + format staged files
pnpm lint-staged

# 2. Type check
pnpm typecheck

# 3. Domain structure (canonical layout, routes)
pnpm validate:domain

# 4. Route catalog + registry (always regenerate locally before commit)
pnpm routes:catalog
git add docs/routes.txt
pnpm routes:catalog:check

# 4b. OpenAPI + Postman drift (when route or OpenAPI generator inputs change)
STAGED_OPENAPI=$(git diff --cached --name-only -- \
  'src/domains/**/*.routes.ts' \
  'src/shared/locales/**/openapi.json' \
  'tooling/openapi/**' \
  'src/scripts/codegen/generate-openapi.ts' \
  'src/scripts/codegen/openapi-*.ts' \
  'src/scripts/codegen/check-api-docs-sync.ts' || true)
if [ -n "$STAGED_OPENAPI" ]; then
  pnpm docs:check
fi

# 5. Migration safety lint (only when migrations/*.sql is staged)
STAGED_MIGRATION_SQL=$(git diff --cached --name-only | grep -E '^migrations/.*\.sql$' || true)
if [ -n "$STAGED_MIGRATION_SQL" ]; then
  pnpm db:migrate:lint
fi

# 5b. Regenerate docs/database/core-be.dbml from migrations/*.sql (local only — not enforced in CI)
if [ -n "$STAGED_MIGRATION_SQL" ]; then
  pnpm tool:generate-dbdiagram
  git add docs/database/core-be.dbml
fi

# 6. Env example in sync with schema (same as CI; report-only, no --fix)
pnpm scripts:sync-env-example || (
  echo "ERROR: .env.example is out of sync with env schema."
  echo "Run: pnpm scripts:sync-env-example --fix  (then add descriptions)"
  exit 1
)

# 7. Secret detection (staged files only; required — install via setup:infra or brew install gitleaks)
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "ERROR: gitleaks is not installed. Install it (e.g. brew install gitleaks) or run: pnpm setup:infra"
  exit 1
fi
gitleaks protect --staged --verbose --redact

# 8. Reject merge conflict markers in staged files
CONFLICT_FILES=$(git diff --cached --name-only -z | xargs -0 grep -lE '^<<<<<<<|^>>>>>>>|^=======$' 2>/dev/null || true)
if [ -n "$CONFLICT_FILES" ]; then
  echo "ERROR: Merge conflict markers found in:"
  echo "$CONFLICT_FILES"
  exit 1
fi

# 9. Reject large files (>1MB) in staged files
LARGE_FILES=""
for file in $(git diff --cached --name-only --diff-filter=d); do
  [ -z "$file" ] && continue
  SIZE=$(git cat-file -s ":$file" 2>/dev/null || echo 0)
  if [ "$SIZE" -gt 1048576 ]; then
    LARGE_FILES="${LARGE_FILES}
  ${file} ($((SIZE / 1024))KB)"
  fi
done
if [ -n "$LARGE_FILES" ]; then
  printf 'ERROR: Files exceed 1MB limit:%s\n' "$LARGE_FILES"
  exit 1
fi
