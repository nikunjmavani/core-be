{
  "$schema": "https://unpkg.com/cursor-hooks@latest/schema/hooks.schema.json",
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node ../agent-os/hooks/cursor-shell-guard.mjs"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node ../agent-os/hooks/cursor-edit-guard.mjs"
      }
    ],
    "beforeReadFile": [
      {
        "command": "node ../agent-os/hooks/cursor-read-guard.mjs"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node ../agent-os/hooks/cursor-mcp-guard.mjs"
      }
    ]
  }
}
