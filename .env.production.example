# =============================================================================
# Production environment — template (NODE_ENV=production)
# =============================================================================
#
# 1. Replace every REPLACE_* value below.
# 2. Push to GitHub Environment secrets and/or Railway service variables.
#    Do not commit filled-in `.env.production` (gitignored).
# 3. For local prod smoke only: cp .env.production.example .env.production && fill, then cp .env.production .env
#
# Boot validation enforces: RS256 JWT keys, SECRETS_ENCRYPTION_KEY,
# deployment connection counts, ALLOWED_ORIGINS, and more — see env-schema.ts.
#
# Full variable reference: `.env.example`
# Runbook: docs/deployment/runbooks/resource-limits.md
# =============================================================================


# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info
TRUST_PROXY=true

FASTIFY_REQUEST_TIMEOUT_MS=30000
FASTIFY_CONNECTION_TIMEOUT_MS=10000
SHUTDOWN_TIMEOUT_MS=30000
# NODE_OPTIONS=--max-old-space-size=REPLACE_HEAP_MB

# --- Database (pooled runtime URL) ---
DATABASE_URL=postgresql://REPLACE_APP_USER:REPLACE_APP_PASSWORD@REPLACE_POOLER_HOST:5432/REPLACE_DATABASE?sslmode=require

# Direct (non-pooler) owner URL — migrations / elevated jobs only
DATABASE_MIGRATION_URL=postgresql://REPLACE_MIGRATION_USER:REPLACE_MIGRATION_PASSWORD@REPLACE_DIRECT_HOST:5432/REPLACE_DATABASE?sslmode=require

DB_MAX=REPLACE_DB_MAX_PER_PROCESS
DB_STATEMENT_TIMEOUT_MS=30000
DB_HTTP_STATEMENT_TIMEOUT_MS=5000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000
DB_SSL_REJECT_UNAUTHORIZED=true

POSTGRES_RESERVED_CONNECTIONS=10
POSTGRES_MAX_CONNECTIONS=REPLACE_POSTGRES_MAX_CONNECTIONS
DEPLOYMENT_PROCESS_COUNT=REPLACE_API_REPLICAS_PLUS_WORKER_REPLICAS
# Or use split counts instead of DEPLOYMENT_PROCESS_COUNT:
# DEPLOYMENT_API_PROCESS_COUNT=REPLACE_API_REPLICA_COUNT
# DEPLOYMENT_WORKER_PROCESS_COUNT=REPLACE_WORKER_REPLICA_COUNT

DB_POOL_ACTIVE_WARN_RATIO=0.8
DB_POOL_ACTIVE_CRITICAL_RATIO=0.95
DB_POOL_CLUSTER_WARN_RATIO=0.8
DB_POOL_CLUSTER_CRITICAL_RATIO=0.95
DB_POOL_ALERT_POLL_INTERVAL_MS=5000
DB_POOL_ALERT_CONSECUTIVE_POLLS=2

# --- Redis (single shared instance) ---
REDIS_URL=redis://REPLACE_REDIS_HOST:6379
# Optional only during transition; if set, keep equal to REDIS_URL.
# REDIS_BULLMQ_URL=redis://REPLACE_REDIS_HOST:6379

# --- Auth (required) ---
JWT_SECRET=REPLACE_JWT_SECRET_MIN_32_CHARACTERS_OR_LONGER
JWT_PRIVATE_KEY=REPLACE_PEM_PRIVATE_KEY_SINGLE_LINE_OR_ESCAPED_NEWLINES
JWT_PUBLIC_KEY=REPLACE_PEM_PUBLIC_KEY_SINGLE_LINE_OR_ESCAPED_NEWLINES
JWT_SIGNING_KID=default
# JWT_PUBLIC_KEYS={"kid2":"REPLACE_PEM_PUBLIC_KEY_FOR_ROTATION"}

SECRETS_ENCRYPTION_KEY=REPLACE_64_HEX_CHARACTERS_32_BYTES
SESSION_MAX_AGE_DAYS=7
GLOBAL_ADMIN_ACCESS_TOKEN_EXPIRY_SECONDS=300

# --- CORS & URLs (no localhost in production FRONTEND_URL) ---
ALLOWED_ORIGINS=https://REPLACE_APP_DOMAIN,https://www.REPLACE_APP_DOMAIN
FRONTEND_URL=https://REPLACE_APP_DOMAIN
API_DOCS_BASE_URL=https://REPLACE_DOCS_HOST/errors

WEBAUTHN_RP_ID=REPLACE_APP_DOMAIN
WEBAUTHN_RP_NAME=REPLACE_APP_DISPLAY_NAME

# --- Rate limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_ORG_MAX=200
RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_URL_ALLOWLIST=REPLACE_ALLOWED_WEBHOOK_HOSTS_COMMA_SEPARATED

# --- Data retention (days) ---
AUDIT_RETENTION_DAYS=90
SESSION_RETENTION_DAYS=30
NOTIFICATION_RETENTION_DAYS=90
TOMBSTONE_RETENTION_DAYS=90
STRIPE_WEBHOOK_EVENT_RETENTION_DAYS=90
USAGE_RECORD_RETENTION_DAYS=365

# --- Email (Resend) ---
RESEND_API_KEY=REPLACE_RESEND_API_KEY
EMAIL_FROM_ADDRESS=noreply@REPLACE_APP_DOMAIN
EMAIL_FROM_NAME=REPLACE_APP_NAME
BLOCK_DISPOSABLE_EMAIL=true

# --- OAuth (production redirect URIs) ---
OAUTH_GOOGLE_CLIENT_ID=REPLACE_GOOGLE_CLIENT_ID
OAUTH_GOOGLE_CLIENT_SECRET=REPLACE_GOOGLE_CLIENT_SECRET
OAUTH_GOOGLE_REDIRECT_URI=https://REPLACE_APP_DOMAIN/auth/oauth/google/callback

OAUTH_GITHUB_CLIENT_ID=REPLACE_GITHUB_CLIENT_ID
OAUTH_GITHUB_CLIENT_SECRET=REPLACE_GITHUB_CLIENT_SECRET
OAUTH_GITHUB_REDIRECT_URI=https://REPLACE_APP_DOMAIN/auth/oauth/github/callback

# --- Stripe (live mode) ---
STRIPE_SECRET_KEY=REPLACE_STRIPE_SK_LIVE
STRIPE_WEBHOOK_SECRET=REPLACE_STRIPE_WHSEC_LIVE
STRIPE_HTTP_TIMEOUT_MS=30000

# --- S3 ---
S3_BUCKET=REPLACE_PROD_BUCKET
S3_REGION=REPLACE_AWS_REGION
S3_ACCESS_KEY_ID=REPLACE_AWS_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=REPLACE_AWS_SECRET_ACCESS_KEY
S3_MAX_ATTEMPTS=3
UPLOAD_ALLOW_SVG=false

# --- Sentry ---
SENTRY_DSN=REPLACE_SENTRY_DSN
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILE_SAMPLE_RATE=0.1
SENTRY_SLOW_TRANSACTION_MS=3000
RAILWAY_GIT_COMMIT_SHA=REPLACE_GIT_SHA_SET_BY_DEPLOY

# --- Metrics (Prometheus scrape; required bearer when METRICS_ENABLED=true in production) ---
METRICS_ENABLED=true
METRICS_BEARER_TOKEN=REPLACE_METRICS_TOKEN_MIN_32_CHARS

# --- Workers ---
WORKER_CONCURRENCY=4
WORKER_HEALTH_PORT=9090
WORKER_HEALTH_STALL_TIMEOUT_MS=300000
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
ENABLE_QUEUE_DASHBOARD=false
ENABLE_MCP_SERVER=false
ENABLE_API_REFERENCE=false

# --- Platform ops ---
GLOBAL_ADMIN_EMAILS=REPLACE_OPS_EMAIL@example.com

# --- Idempotency / DLQ (defaults usually fine) ---
DLQ_DEPTH_WARN_THRESHOLD=10
IDEMPOTENCY_CARDINALITY_WARN_THRESHOLD=50000
IDEMPOTENCY_CARDINALITY_CRITICAL_THRESHOLD=200000

# --- Response encryption (optional) ---
ENABLE_RESPONSE_ENCRYPTION=false
# RESPONSE_ENCRYPTION_KEY=REPLACE_64_HEX_IF_ENABLED
