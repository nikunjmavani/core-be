# =============================================================================
# Local overrides template — copy to `.env.local` (gitignored)
# =============================================================================
# Loaded after `.env` — values here overwrite `.env`. Use for machine-specific or secret overrides.
# Copy: cp .env.local.example .env.local
# Full reference and defaults: see `.env.example`
# =============================================================================

# Typical local overrides (copy this block into `.env.local` and edit; values override `.env`):
NODE_ENV=local
LOG_LEVEL=debug
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://core:core@127.0.0.1:5432/core
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=REPLACE_JWT_SECRET_MIN_32_CHARACTERS_OR_LONGER
AUDIT_RETENTION_DAYS=90
SESSION_RETENTION_DAYS=30

# Optional: opt-in to Testcontainers-based integration tests (set to 1 to enable)
# USE_TESTCONTAINERS=1

