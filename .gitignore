# Dependencies
node_modules/
**/node_modules/

# pnpm
.pnpm-store/

# Build
dist/

# Environment: only `.env.example` and `.env.setup.example` are committed.
# `.env.<environment>` files are gitignored copies created by `pnpm github:sync` and pushed
# to GitHub Environments via `pnpm github:sync <environment>`.
# `.env.local` (gitignored) is a machine-specific override that wins over `.env.<NODE_ENV>`
# for local dev only (e.g. point DATABASE_URL/REDIS_URL at the local Docker Compose stack);
# use `.env.example` as the schema reference for variable names.
.env*
!.env.example
!.env.setup.example

# Docker Compose machine-local overrides (auto-merged by compose; never shared with team/CI)
docker-compose.override.yml
compose.override.yml

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/vitest.workspace.ts
.idea/
*.swp
*.swo
*~
*.bak

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Coverage
coverage/
coverage-*/
route-coverage-observed/

# SonarQube scanner working dir (analysis task metadata)
.scannerwork/

# Generated docs (run pnpm docs:generate / pnpm docs:postman to recreate)
docs/openapi/openapi.json
docs/openapi/openapi.*.json
docs/postman-collection.json

# Drizzle Kit scratch output (drafting only). Hand-written, timestamp-named
# migrations/*.sql applied by `pnpm db:migrate` are the source of truth; the
# drizzle-kit generate snapshot/journal must never be committed or applied.
/drizzle/

# Vite/Vitest caches (should never be in repo)
**/.vite/
src/tests/node_modules/

# Stryker mutation-testing sandboxes (local only)
.stryker-tmp/

# Security scan reports
.semgrep/

# Generated SBOM (run pnpm sbom:generate to recreate; CI attests it per-commit)
sbom.cyclonedx.json

# Local-only reports (do not commit)
# Generic report files generated by tools/skills/rules
TEST_REPORT.md

# User-specific agent MCP config (may contain API keys).
# Committed templates (secret-free): .mcp.default.json (default auto-start pair —
# codegraph + headroom), .mcp.example.json (full set), and .cursor/mcp.example.json.
# Scaffold .mcp.json with `pnpm mcp:setup` (full) / `pnpm mcp:setup:default` (pair),
# or let `pnpm setup:local` declare the default pair for you.
.cursor/mcp.json
.mcp.json
agent-os/mcp/mcp.json

# Claude Code — ignore everything except tracked project config
# Use .claude/* (not .claude/) so the !negations below actually re-include
# these entries — git cannot re-include children of a wholly-excluded dir.
.claude/*
!.claude/settings.json
!.claude/agents
!.claude/skills
!.claude/hooks
!.claude/commands
reports/
**/reports/
**/*-report.*
**/*.report.*
*REPORT*.md

# Setup automation (secrets + provisioned state)
tooling/setup.secrets.json
.setup-state.json

# Understand Anything — fully regenerable analysis output
.understand-anything/
.cache/

# Local dashboards orchestrator (pnpm dashboards:*) — detached process logs + pidfiles
.dashboards/

# Local scratch output from agent skills/tools (deep-research reports, moodboards,
# market dumps, etc.). Machine-local and regenerable — never part of the codebase.
outputs/

# vendored Tailwind Play CDN for the local dashboards hub (regenerable: curl https://cdn.tailwindcss.com)
tooling/dev/dashboards/tailwind.js
# vendored gridstack for the resizable dashboard grid (regenerable: curl https://cdn.jsdelivr.net/npm/gridstack@11/dist/gridstack-all.min.js + .../gridstack.min.css)
tooling/dev/dashboards/gridstack.js
tooling/dev/dashboards/gridstack.css
