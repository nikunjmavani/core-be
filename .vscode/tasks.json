{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: API server",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "Dev: Worker",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "dev:worker"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "Validate",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "validate"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Test: unit",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test:unit"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Test: all",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "test"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
