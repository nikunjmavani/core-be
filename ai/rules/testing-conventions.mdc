description: Enforces testing layout (src/tests = common, domains = per-domain) and invokes test-generator when tests or pure layers change.
globs: src/domains/**/__tests__/**/*.test.ts, src/tests/**/*.test.ts, src/domains/**/*.validator.ts, src/domains/**/*.serializer.ts, src/shared/utils/**/*.ts, src/domains/**/workers/**/*.ts
alwaysApply: false
