# --- Organization capability flags (deployment mode: B2C / B2B / hybrid) ---
# Toggle the two organization kinds independently so one codebase serves a
# personal-only (B2C), team-only (B2B), or hybrid product. At least one MUST be
# true or the API/worker refuses to boot. They gate signup auto-provisioning,
# team-org creation, the login default org, and the /users/me capabilities the
# frontend reads — never the core scoping path (signed `org` JWT claim →
# Postgres RLS), which is identical in every mode.
#   Hybrid (default): both true     — personal workspace AND create/join teams
#   B2C:  PERSONAL=true  TEAM=false  — personal workspace only; team create → 403
#   B2B:  PERSONAL=false TEAM=true   — no personal workspace; users live in a team
# Defaults below = hybrid; leave commented to keep the default. Docs:
# docs/reference/architecture/personal-vs-team-organizations.md
# PERSONAL_ORGANIZATION_ENABLED=true
# TEAM_ORGANIZATION_ENABLED=true
# Per-owner cap on TEAM orgs one user may create (anti-abuse; personal exempt). Default 20.
# MAX_TEAM_ORGANIZATIONS_PER_OWNER=20
# Synced from env schema (add description/placeholder as needed)
# STRIPE_WEBHOOK_EVENT_CATCHUP_WINDOW_MINUTES=
# STRIPE_WEBHOOK_EVENT_CATCHUP_PAGE_SIZE=
# STRIPE_WEBHOOK_EVENT_CATCHUP_CRON=

# -----------------------------------------------------------------------------
# Policy flags (behaviour + security posture — replaced the former NODE_ENV branches)
# -----------------------------------------------------------------------------
# Runtime code never compares NODE_ENV, and NODE_ENV no longer SELECTS any default — every flag below
# has a STATIC production-safe default in src/shared/config/env-schema.ts. So this template ships ALL
# the local-development values ACTIVE (uncommented) so `pnpm dev` boots against localhost and behaves
# like a dev box; a deployed `.env` omits them to keep the hardened production defaults. Booleans
# accept `true`/`1` or `false`/`0`. The Category-B / safety flags additionally carry a schema refine
# that rejects the unsafe value in production. Every switch lives in env — nothing derives from NODE_ENV.

# ── Category-A (behaviour; static production-safe default, dev value set here) ──
# Captcha fails OPEN (skips) when Turnstile is unconfigured. Default: false (fail closed).
CAPTCHA_FAIL_OPEN=true
# Fail boot on scheduler/worker registry drift instead of warning. Default: true.
SCHEDULER_REGISTRY_AUDIT_STRICT=false
# Coarsen the Server-Timing header to 5ms (timing side-channel guard). Default: true.
SERVER_TIMING_COARSE=false
# Apply the pre-close drain pause (for runtimes behind a load balancer). Default: true.
SHUTDOWN_DRAIN_ENABLED=false
# Skip process-level shared-singleton teardown on close (per-worker Vitest harness). Default: false; the test harness sets true.
# SHUTDOWN_SKIP_SHARED_TEARDOWN=false
# Report missing i18n keys for non-default locales to Sentry (else debug-log). Default: true.
I18N_REPORT_MISSING_KEYS=false
# Pretty-print logs via pino-pretty. Default: false (JSON).
LOG_PRETTY=true
# Reduced Sentry sampling defaults (production volume) when SENTRY_*_SAMPLE_RATE unset. Default: true.
SENTRY_REDUCED_SAMPLING=false
# Enable Sentry SDK debug logging. Default: false.
SENTRY_DEBUG=true

# ── Category-B (security; a refine forbids the unsafe value in production) ──
# Permit the CAPTCHA_BYPASS_HEADER dev affordance. Must be false in production/staging. Default: false.
# CAPTCHA_BYPASS_ALLOWED=false
# Require CSRF double-submit on cookie-session routes when Origin is absent. Must be true in production. Default: true.
# SESSION_ORIGIN_CSRF_REQUIRED=true
# Reject outbound webhook targets when the allowlist is empty (SSRF guard). Must be true in production. Default: true.
# WEBHOOK_ALLOWLIST_REQUIRED=true
# Require a bearer token on the worker /metrics endpoint. Must be true in production. Default: true.
# METRICS_AUTH_REQUIRED=true

# ── Boot-time safety checks (default HARDENED; active-false here for local `pnpm dev` against localhost) ──
# Each defaults true (enforced) everywhere and a refine locks it on in production. A deployed `.env`
# OMITS these (keeping the hardened default); this template sets them false so local dev boots.
# Fail boot when the Postgres server TLS certificate is not verified.
DATABASE_TLS_ENFORCED=false
# Fail boot when DATABASE_URL connects as a superuser / BYPASSRLS role (collapses tenant RLS).
DATABASE_RLS_SAFETY_ENFORCED=false
# Require explicit deployment replica counts to validate the Postgres connection budget.
DATABASE_CONNECTION_BUDGET_ENFORCED=false
# Fail boot on plaintext redis:// to a public host (private/internal hosts stay allowed).
REDIS_TLS_ENFORCED=false
# Fail boot when TRUST_PROXY is unset/false (behind a load balancer the client IP collapses).
TRUST_PROXY_REQUIRED=false

# ── Test affordances (a refine forbids the unsafe value in production) ──
# Marks the process as a test run — the master gate for test-only affordances (today the destructive
# DB/Redis wipe helpers). Must be false in production. Default: false; the test harness sets true.
# Set true in .env.local to allow `cleanupDatabase`/`cleanupTestRedis` against a local dev DB.
# TEST_MODE=false
# ioredis ready-check on the cache / BullMQ connections. Must be true in production. Default: true
# (the test harness sets false). Read via raw process.env by the clients for load-order safety.
# REDIS_READY_CHECK_ENABLED=true
# Lift the strict public/authenticated rate-limit caps to 5000 (loopback E2E + dev UX). Must be false
# in production. Default: false; active-true here so local `pnpm dev` is not throttled.
RATE_LIMIT_RELAXED_CAPS=true
# Allow the chaos suite's RUN_REDIS_TESTS=0 to force the in-memory rate-limit store. Must be false in
# production. Default: false; the chaos harness sets it true.
# RATE_LIMIT_IN_MEMORY_FALLBACK_ALLOWED=true
# Synced from env schema (add description/placeholder as needed)
# INVITATION_MAX_PENDING_PER_ORG=
