# =============================================================================
# core-be environment variables
# =============================================================================
#
# Copy to `.env` in the project root (never commit `.env`).
# Optional overrides: copy `.env.local.example` → `.env.local` — loaded **after** `.env` (same keys win).
# Environment-specific templates:
#   `.env.development.example` → hosted dev (`NODE_ENV=development`)
#   `.env.production.example`  → prod secrets template (`NODE_ENV=production`)
# Source of truth: `src/shared/config/env-schema.ts` (validated at startup).
#
# Legend:
#   - Uncommented lines = typical local dev minimum (also used as deploy hints
#     for GitHub environment secrets when marked "deploy-required").
#   - Commented lines = optional or production-only; uncomment to override defaults.
#
# How to obtain values: docs/integrations/credentials-and-env.md
# Production checklist: docs/deployment/runbooks/resource-limits.md
# =============================================================================


# -----------------------------------------------------------------------------
# Server & process
# -----------------------------------------------------------------------------

# HTTP listen port. Integer 1–65535. Default: 3000
PORT=3000

# Bind address. Default: 0.0.0.0
HOST=0.0.0.0

# Runtime mode. One of: local | development | staging | production | test
NODE_ENV=local

# Pino log level. Examples: trace | debug | info | warn | error. Default: info
LOG_LEVEL=debug

# Trust X-Forwarded-* from reverse proxy (required behind load balancer).
# Values: true | false | 1 | 0. Unset = false
# TRUST_PROXY=true

# Fastify / Node HTTP timeouts (milliseconds)
# FASTIFY_REQUEST_TIMEOUT_MS=30000      # Max request duration. Default: 30000
# FASTIFY_CONNECTION_TIMEOUT_MS=10000   # TCP connect. Default: 10000
# FASTIFY_KEEP_ALIVE_TIMEOUT_MS=72000   # Default: 72000
# FASTIFY_HEADERS_TIMEOUT_MS=73000      # Must exceed keep-alive. Default: 73000

# Graceful shutdown budget (ms). Default: 30000
# SHUTDOWN_TIMEOUT_MS=30000

# Node.js heap cap — set ~75% of container memory limit (MiB).
# See docs/deployment/runbooks/resource-limits.md
# NODE_OPTIONS=--max-old-space-size=384


# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------

# deploy-required — Primary connection string (API + worker runtime).
# Use pooled Neon/Railway endpoint (-pooler host or ?pgbouncer=true) when available.
DATABASE_URL=postgresql://user:password@host:5432/core

# Elevated-privilege URL for migrations only (`pnpm db:migrate`). Non-pooler direct host.
# DATABASE_MIGRATION_URL=postgresql://owner:password@host:5432/core

# Pool size per process (postgres.js `max`). Default: 10
# DB_MAX=10

# Connection pool tuning (seconds unless noted)
# DB_IDLE_TIMEOUT=30           # Idle connection recycle. Default: 30
# DB_CONNECT_TIMEOUT=10        # Connect timeout. Default: 10
# DB_MAX_LIFETIME=1800         # Max connection age (seconds). Default: 1800

# Statement timeouts (milliseconds). 0 = disable that layer.
# DB_STATEMENT_TIMEOUT_MS=30000              # Per-connection default. Default: 30000
# DB_HTTP_STATEMENT_TIMEOUT_MS=5000          # HTTP SET LOCAL per request. Default: 5000
# DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000  # Stuck transactions. Default: 30000

# Production hardening item 2 (RLS unpinning): when true, the per-HTTP-request transaction
# pin is bypassed and services must wrap their unit-of-work in withOrganizationDatabaseContext.
# Default: false. Roll out per-environment after migrating services to scoped contexts.
# DB_RLS_SCOPED_CONTEXTS=false

# TLS: strict server cert verification when true. sslmode=verify-ca|verify-full in URL always strict.
# DB_SSL_REJECT_UNAUTHORIZED=true

# Connection budget (production sizing — see resource-limits runbook)
# POSTGRES_RESERVED_CONNECTIONS=10   # Headroom for admin/migrations. Default: 10
# POSTGRES_MAX_CONNECTIONS=100       # Override when SHOW max_connections is wrong (pooler)
# DEPLOYMENT_PROCESS_COUNT=3         # Shorthand: api_replicas + worker_replicas
# DEPLOYMENT_API_PROCESS_COUNT=2     # Optional split count when not using DEPLOYMENT_PROCESS_COUNT
# DEPLOYMENT_WORKER_PROCESS_COUNT=1

# Pool exhaustion alerting (Sentry; API polls on boot — independent of METRICS_ENABLED)
# DB_POOL_ACTIVE_WARN_RATIO=0.8              # In-process org RLS checkouts / DB_MAX. Default: 0.8
# DB_POOL_ACTIVE_CRITICAL_RATIO=0.95         # Default: 0.95
# DB_POOL_CLUSTER_WARN_RATIO=0.8             # pg_stat_activity vs allowed budget. Default: 0.8
# DB_POOL_CLUSTER_CRITICAL_RATIO=0.95        # Default: 0.95
# DB_POOL_ALERT_POLL_INTERVAL_MS=5000        # Poll interval. Default: 5000
# DB_POOL_ALERT_CONSECUTIVE_POLLS=2          # Polls before alert. Default: 2


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# deploy-required — Shared Redis for cache, idempotency, rate limits, circuit breakers, and BullMQ.
REDIS_URL=redis://host:6379

# Optional BullMQ override. Leave unset for the current single-Redis topology.
# REDIS_BULLMQ_URL=redis://host:6379


# -----------------------------------------------------------------------------
# Authentication & session
# -----------------------------------------------------------------------------

# deploy-required — HS256 fallback / dev; min 32 characters. Production also needs RS256 keys below.
JWT_SECRET=your-jwt-secret-min-32-chars-minimum-length

# Production RS256 (required when NODE_ENV=production)
# JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# JWT_SIGNING_KID=default
# JWT_PUBLIC_KEYS={"default":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}

# Session cookie max age (days). Default: 7
# SESSION_MAX_AGE_DAYS=7

# Comma-separated emails receiving super_admin on login/refresh (platform ops).
# GLOBAL_ADMIN_EMAILS=ops@example.com

# Shorter access-token TTL for global admins (seconds). Default: 300
# GLOBAL_ADMIN_ACCESS_TOKEN_EXPIRY_SECONDS=300

# WebAuthn / passkeys
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=YourApp


# -----------------------------------------------------------------------------
# CORS & public URLs
# -----------------------------------------------------------------------------

# deploy-required in production — Comma-separated allowed origins (no trailing slash).
ALLOWED_ORIGINS=http://localhost:3000

# Frontend base URL (used in emails, OAuth redirects). Must be http(s) URL.
FRONTEND_URL=http://localhost:3000

# Base URL for error documentation links in API responses.
# API_DOCS_BASE_URL=https://docs.yourdomain.com/errors


# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------

# Global rate limit per IP/window. Default: 100
RATE_LIMIT_MAX=100

# Per-organization rate limit. Default: 200
# RATE_LIMIT_ORG_MAX=200

# Sliding window (ms). Default: 60000
RATE_LIMIT_WINDOW_MS=60000

# Comma-separated hostnames allowed for outbound webhook delivery (extra restriction).
# WEBHOOK_URL_ALLOWLIST=hooks.example.com,partner.example.com


# -----------------------------------------------------------------------------
# Email (Resend — https://resend.com)
# -----------------------------------------------------------------------------

# RESEND_API_KEY=re_...
# RESEND_HTTP_TIMEOUT_MS=30000     # Outbound API timeout (ms). Default: 30000
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME=YourApp
# BLOCK_DISPOSABLE_EMAIL=true      # true | false. Default: true


# -----------------------------------------------------------------------------
# OAuth
# -----------------------------------------------------------------------------

# Google — redirect URI must match Google Cloud Console exactly
# OAUTH_GOOGLE_CLIENT_ID=...
# OAUTH_GOOGLE_CLIENT_SECRET=...
# OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/oauth/google/callback
# Default when unset: ${FRONTEND_URL}/auth/oauth/google/callback

# GitHub — callback URL must match GitHub OAuth App settings
# OAUTH_GITHUB_CLIENT_ID=...
# OAUTH_GITHUB_CLIENT_SECRET=...
# OAUTH_GITHUB_REDIRECT_URI=http://localhost:3000/auth/oauth/github/callback
# Default when unset: ${FRONTEND_URL}/auth/oauth/github/callback


# -----------------------------------------------------------------------------
# Stripe (https://stripe.com)
# -----------------------------------------------------------------------------

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_HTTP_TIMEOUT_MS=30000       # Node client per-request timeout (ms). Default: 30000


# -----------------------------------------------------------------------------
# Object storage (S3-compatible)
# -----------------------------------------------------------------------------

# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_MAX_ATTEMPTS=3                  # AWS SDK retries. Default: 3

# Allow image/svg+xml uploads (sanitized on confirm). true | false. Default: false
# UPLOAD_ALLOW_SVG=false


# -----------------------------------------------------------------------------
# Observability — Sentry
# -----------------------------------------------------------------------------

# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=local
# SENTRY_TRACES_SAMPLE_RATE=0.05     # 0.0–1.0 baseline; errors/slow paths always sampled
# SENTRY_PROFILE_SAMPLE_RATE=0.1     # 0.0–1.0
# SENTRY_SLOW_TRANSACTION_MS=3000    # Always trace slower transactions (ms). Default: 3000
# RAILWAY_GIT_COMMIT_SHA=            # Release tag in Sentry (set by deploy)


# -----------------------------------------------------------------------------
# Observability — Prometheus & OpenTelemetry
# -----------------------------------------------------------------------------

# Prometheus text format at GET /metrics (API; worker on WORKER_HEALTH_PORT).
# METRICS_ENABLED=false              # true | false. Default: false
# METRICS_BEARER_TOKEN=              # Required in production when METRICS_ENABLED=true (min 32 chars)

# OpenTelemetry traces (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com
# OTEL_SERVICE_NAME=core-be-api      # Default: core-be-api / core-be-worker


# -----------------------------------------------------------------------------
# Workers & BullMQ
# -----------------------------------------------------------------------------

# Default worker concurrency when per-queue overrides unset. Default: 4
# WORKER_CONCURRENCY=4
# WORKER_CONCURRENCY_MAIL=4
# WORKER_CONCURRENCY_NOTIFY=4
# WORKER_CONCURRENCY_WEBHOOK=4
# WORKER_CONCURRENCY_STRIPE=4

# Worker HTTP health/metrics port. Default: 9090
# WORKER_HEALTH_PORT=9090

# Max age of queue heartbeats before worker /health/live returns 503 (ms). Default: 300000
# WORKER_HEALTH_STALL_TIMEOUT_MS=300000

# Bull Board at /admin/queues (super_admin JWT). true | false. Default: false
# ENABLE_QUEUE_DASHBOARD=false

# Master switch for repeatable retention/cleanup schedulers. true | false. Default: true
# SCHEDULER_ENABLED=true

# IANA timezone for cron interpretation (e.g. America/New_York). Unset = server default
# SCHEDULER_TIMEZONE=UTC


# -----------------------------------------------------------------------------
# Data retention (days)
# -----------------------------------------------------------------------------

# deploy-required — Audit log retention before purge worker.
AUDIT_RETENTION_DAYS=90

# deploy-required — Revoked/expired session cleanup.
SESSION_RETENTION_DAYS=30

# In-app notifications. Default: 90
# NOTIFICATION_RETENTION_DAYS=90

# Tombstoned rows (webhooks, memberships, etc.) before hard delete. Default: 90
# TOMBSTONE_RETENTION_DAYS=90

# Stripe webhook ledger (terminal rows). Default: 90
# STRIPE_WEBHOOK_EVENT_RETENTION_DAYS=90


# -----------------------------------------------------------------------------
# Scheduled jobs (cron) — optional overrides (built-in defaults when unset)
# -----------------------------------------------------------------------------

# AUDIT_RETENTION_CRON=0 3 * * *
# SESSION_CLEANUP_CRON=0 4 * * *
# STRIPE_WEBHOOK_EVENT_RETENTION_CRON=0 5 * * *
# STRIPE_WEBHOOK_EVENT_RECLAIM_CRON=*/15 * * * *
# STRIPE_WEBHOOK_EVENT_RECLAIM_BATCH_SIZE=100
# MAIL_OUTBOX_SWEEPER_CRON=*/10 * * * *
# MAIL_OUTBOX_SWEEP_PENDING_MINUTES=15
# MAIL_OUTBOX_SWEEP_BATCH_SIZE=100
# WEBHOOK_TOMBSTONE_RETENTION_CRON=45 5 * * *
# ORGANIZATION_NOTIFICATION_POLICY_TOMBSTONE_RETENTION_CRON=46 5 * * *
# USER_TOMBSTONE_RETENTION_CRON=47 5 * * *
# ORGANIZATION_TOMBSTONE_RETENTION_CRON=48 5 * * *
# MEMBERSHIP_TOMBSTONE_RETENTION_CRON=49 5 * * *
# MEMBER_ROLE_TOMBSTONE_RETENTION_CRON=50 5 * * *
# ORGANIZATION_API_KEY_TOMBSTONE_RETENTION_CRON=51 5 * * *
# UPLOAD_TOMBSTONE_RETENTION_CRON=52 5 * * *
# IDEMPOTENCY_CARDINALITY_CRON=0 6 * * *
# DLQ_DEPTH_CRON=*/5 * * * *

# Audit cold export to S3 (requires S3_BUCKET)
# AUDIT_EXPORT_ENABLED=false
# AUDIT_EXPORT_S3_PREFIX=audit/export
# AUDIT_EXPORT_BATCH_SIZE=5000
# AUDIT_EXPORT_CRON=15 2 * * *


# -----------------------------------------------------------------------------
# Idempotency & dead-letter monitoring
# -----------------------------------------------------------------------------

# IDEMPOTENCY_CARDINALITY_SCAN_MAX=200000
# IDEMPOTENCY_CARDINALITY_WARN_THRESHOLD=50000
# IDEMPOTENCY_CARDINALITY_CRITICAL_THRESHOLD=200000

# Alert when DLQ waiting+failed jobs >= threshold. Default: 10
# DLQ_DEPTH_WARN_THRESHOLD=10


# -----------------------------------------------------------------------------
# Security — encryption at rest & response obfuscation
# -----------------------------------------------------------------------------

# AES-256-GCM for MFA TOTP and webhook signing secrets (64 hex chars = 32 bytes).
# Required when NODE_ENV=production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SECRETS_ENCRYPTION_KEY=

# Optional API response obfuscation (AES-256-CBC; client must share key)
# ENABLE_RESPONSE_ENCRYPTION=false
# RESPONSE_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------

# MCP tools at POST /api/v1/mcp (JWT + admin). true | false. Default: false
# ENABLE_MCP_SERVER=false

# Serve OpenAPI reference UI. true | false. Default: false
# ENABLE_API_REFERENCE=false
# OPENAPI_SPEC_PATH=docs/openapi/openapi.json


# =============================================================================
# Local tooling (not validated by env schema — safe to omit for API/worker)
# =============================================================================

# Docker Compose chaos / Toxiproxy — docs/reference/reliability/chaos-testing.md
# TOXIPROXY_URL=http://127.0.0.1:8474
# CHAOS_TOXIPROXY_POSTGRES_UPSTREAM=postgres:5432
# CHAOS_TOXIPROXY_REDIS_UPSTREAM=redis:6379

# Cursor Context7 MCP — https://context7.com/dashboard
# CONTEXT7_API_KEY=ctx7sk-...

# Postman collection upload — docs/reference/api/api-documentation.md
# POSTMAN_API_KEY=PMAK-...
# POSTMAN_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# k6 load tests — docs/reference/testing/load-testing.md
# BASE_URL=http://localhost:3000
# TEST_EMAIL=demo@example.com
# TEST_PASSWORD=DemoPassword123!
# TEST_TOKEN=
# TEST_ORG_ID=
# ADMIN_TOKEN=
# Synced from env schema (add description/placeholder as needed)
# REDIS_KEY_PREFIX=
# ENABLE_QUEUE_DASHBOARD_MUTATIONS=
# CAPTCHA_PROVIDER=
# CAPTCHA_SECRET=
# CAPTCHA_SITE_KEY=
# CAPTCHA_BYPASS_HEADER=
