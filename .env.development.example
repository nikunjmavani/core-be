# =============================================================================
# Development environment — template (NODE_ENV=development)
# =============================================================================
#
# 1. Copy:  cp .env.development.example .env.development
# 2. Replace every REPLACE_* value below.
# 3. Run:   cp .env.development .env   (the app loads `.env` via dotenv at startup)
#
# Docker Compose defaults (pnpm compose:up): user/db `core`, password `core`.
# Deployed dev (Railway, etc.): use your provider connection strings instead.
#
# Not committed: `.env.development` is gitignored. This `.example` file is committed.
# Full variable reference: `.env.example`
# =============================================================================


# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug
TRUST_PROXY=false

# --- Database (Docker Compose default below) ---
DATABASE_URL=postgresql://core:core@127.0.0.1:5432/core
# DATABASE_MIGRATION_URL=postgresql://REPLACE_MIGRATION_USER:REPLACE_MIGRATION_PASSWORD@REPLACE_MIGRATION_HOST:5432/core

DB_MAX=10
DB_STATEMENT_TIMEOUT_MS=30000
DB_HTTP_STATEMENT_TIMEOUT_MS=5000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000

# --- Redis (Docker Compose default below) ---
REDIS_URL=redis://127.0.0.1:6379
# Omit locally — BullMQ uses REDIS_URL in the current single-Redis topology.
# REDIS_BULLMQ_URL=redis://127.0.0.1:6379

# --- Auth (min 32 chars for JWT_SECRET) ---
JWT_SECRET=REPLACE_JWT_SECRET_MIN_32_CHARACTERS_OR_LONGER

# RS256 optional in development; required when NODE_ENV=production
# JWT_PRIVATE_KEY=REPLACE_PEM_PRIVATE_KEY_OR_MULTILINE
# JWT_PUBLIC_KEY=REPLACE_PEM_PUBLIC_KEY_OR_MULTILINE
# JWT_SIGNING_KID=default

# Optional in dev; required in production for MFA/webhook secrets at rest
# SECRETS_ENCRYPTION_KEY=REPLACE_64_HEX_CHARS

SESSION_MAX_AGE_DAYS=7

# --- CORS & URLs ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
# API_DOCS_BASE_URL=https://REPLACE_DOCS_HOST/errors

# --- Rate limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_ORG_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# --- Data retention (days) ---
AUDIT_RETENTION_DAYS=90
SESSION_RETENTION_DAYS=30
NOTIFICATION_RETENTION_DAYS=90
TOMBSTONE_RETENTION_DAYS=90

# --- Email (Resend) ---
# RESEND_API_KEY=REPLACE_RESEND_API_KEY
# EMAIL_FROM_ADDRESS=noreply@REPLACE_DEV_DOMAIN
# EMAIL_FROM_NAME=REPLACE_APP_NAME
# BLOCK_DISPOSABLE_EMAIL=false

# --- OAuth ---
# OAUTH_GOOGLE_CLIENT_ID=REPLACE_GOOGLE_CLIENT_ID
# OAUTH_GOOGLE_CLIENT_SECRET=REPLACE_GOOGLE_CLIENT_SECRET
# OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/oauth/google/callback

# OAUTH_GITHUB_CLIENT_ID=REPLACE_GITHUB_CLIENT_ID
# OAUTH_GITHUB_CLIENT_SECRET=REPLACE_GITHUB_CLIENT_SECRET
# OAUTH_GITHUB_REDIRECT_URI=http://localhost:3000/auth/oauth/github/callback

# --- Stripe (test mode) ---
# STRIPE_SECRET_KEY=REPLACE_STRIPE_SK_TEST
# STRIPE_WEBHOOK_SECRET=REPLACE_STRIPE_WHSEC_TEST

# --- S3 ---
# S3_BUCKET=REPLACE_DEV_BUCKET
# S3_REGION=REPLACE_AWS_REGION
# S3_ACCESS_KEY_ID=REPLACE_AWS_ACCESS_KEY_ID
# S3_SECRET_ACCESS_KEY=REPLACE_AWS_SECRET_ACCESS_KEY

# --- Sentry (recommended on shared dev) ---
# SENTRY_DSN=REPLACE_SENTRY_DSN
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=1.0
# SENTRY_PROFILE_SAMPLE_RATE=1.0

# --- Workers ---
WORKER_CONCURRENCY=4
SCHEDULER_ENABLED=true
ENABLE_QUEUE_DASHBOARD=false
ENABLE_MCP_SERVER=false

# --- Platform ops (optional) ---
# GLOBAL_ADMIN_EMAILS=REPLACE_OPS_EMAIL@example.com

# --- Connection budget (unset locally; set on hosted dev if validating budget at boot) ---
# DEPLOYMENT_PROCESS_COUNT=2
# POSTGRES_RESERVED_CONNECTIONS=10
