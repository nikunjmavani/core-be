# =============================================================================
# Setup Tokens — Copy this file to .setup/.setup-credentials and fill your keys
# =============================================================================
#   cp .setup-credentials.example .setup/.setup-credentials   # (mkdir -p .setup first)
#
# This `.setup-credentials.example` template lives at the repo root (next to
# .env.example) for discoverability. The real credentials file lives in the
# gitignored `.setup/` directory — `.setup/.setup-credentials` — alongside
# `.setup/.setup-state.json`. `pnpm setup:infra:init` creates it for you.
#
# Each variable has the URL where to get the token. Never commit real tokens.
# It is intentionally NOT a .env.<environment> file: these are setup-tooling
# INPUT credentials, separate from app runtime config. See
# tooling/setup/SETUP_INFRA_PREREQUISITES.md.
#
# Edit tooling/setup/setup.config.json to change providers, environments, or
# branch mappings.
# =============================================================================

# --- Neon Postgres ---
# Get API key: https://console.neon.tech/app/settings/api-keys
# Create a new key, copy the value (starts with napi_)
NEON_API_KEY=

# Get Org ID: https://console.neon.tech/app/settings → Organization → General
NEON_ORG_ID=

# --- AWS ---
# Get access keys: https://console.aws.amazon.com/iam/home#/users
# Create an IAM user with AmazonS3FullAccess + IAMFullAccess
# Then Security credentials → Create access key → Application running outside AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Sentry ---
# Get auth token: https://sentry.io/settings/auth-tokens/new-token/
# Scopes needed: project:admin, project:write, project:read
SENTRY_AUTH_TOKEN=

# Get org slug: https://sentry.io/settings/ → Organization Settings → General
# Human-readable org slug used by sentry-cli (e.g. "albetrios").
SENTRY_ORG=

# --- Resend ---
# Get API key: https://resend.com/api-keys
# Create key with Full access permission
RESEND_API_KEY=

# --- GitHub ---
# Get personal access token: https://github.com/settings/tokens
# Classic token scopes: repo, admin:repo_hook
# When set, no gh auth login or browser prompt is needed.
GITHUB_TOKEN=

# --- Railway ---
# Account / project-wide token used at setup time. Authenticates via Bearer header.
# Get token: https://railway.com/account/tokens (NOT the per-project tokens page).
# Used to: create the project, list user projects, mint per-environment project
# tokens via `projectTokenCreate`, and read/write variables across environments.
# Stays in .setup-credentials only; never pushed to GitHub Environments or Railway service
# variables. Per-environment runtime tokens are minted from this and persisted to
# state, then written into each `.env.<env>` as `RAILWAY_TOKEN`.
RAILWAY_API_TOKEN=

# --- Cloudflare Turnstile (PROVISIONED by setup — you only provide Cloudflare creds) ---
# setup:infra CREATES one Turnstile widget per environment and writes
# CAPTCHA_PROVIDER/SITE_KEY/SECRET into each .env.<environment> for you. Provide:
#   1. API token (Turnstile:Edit): https://dash.cloudflare.com/profile/api-tokens
#      Create Token → Custom token → permission "Turnstile : Edit" → Create.
#   2. Account ID: Cloudflare dashboard → any domain → Overview → right sidebar.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- App per-environment secrets — NOT here; prompted at apply → .env.<environment> ---
# These differ per environment (the env is the FILE, not a key suffix). setup:infra prompts you
# for them from stdin during apply and writes them into .env.development / .env.production:
#   Stripe:    STRIPE_SECRET_KEY=  STRIPE_WEBHOOK_SECRET=  (sk_test_… dev, sk_live_… prod)
#   OAuth:     OAUTH_GOOGLE_CLIENT_ID=  OAUTH_GOOGLE_CLIENT_SECRET=  OAUTH_GOOGLE_REDIRECT_URI=
#              OAUTH_GITHUB_CLIENT_ID=  OAUTH_GITHUB_CLIENT_SECRET=  OAUTH_GITHUB_REDIRECT_URI=
#              (app names: core-be-development, core-be for production — see setup:infra guide)
#   Postman:   POSTMAN_API_KEY=  (script creates the workspace + uploads the collection)
#   Scalar:    SCALAR_API_KEY=  SCALAR_NAMESPACE=  (optional SCALAR_SLUG=)
#   PostHog:   POSTHOG_PERSONAL_API_KEY=  (setup resolves POSTHOG_KEY + POSTHOG_HOST)
# Their setup:infra providers read/validate these from each .env.<environment>.
